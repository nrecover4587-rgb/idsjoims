{
    "name": "JoinIDs Bot",
    "description": "A Telegram bot to manage multiple accounts and auto-join channels/groups.",
    "keywords": ["telegram", "bot", "golang", "join", "accounts"],
    "repository": "https://github.com/joinids/bot",
    "stack": "container",
    "env": {
        "BOT_TOKEN": {
            "description": "Your Telegram bot token from @BotFather.",
            "value": "",
            "required": true
        },
        "OWNER_ID": {
            "description": "Your Telegram user ID (get from @userinfobot).",
            "value": "",
            "required": true
        },
        "MONGO_URI": {
            "description": "Your MongoDB connection string (MongoDB Atlas recommended).",
            "value": "",
            "required": true
        },
        "API_ID": {
            "description": "Your Telegram API ID from my.telegram.org.",
            "value": "",
            "required": true
        },
        "API_HASH": {
            "description": "Your Telegram API Hash from my.telegram.org.",
            "value": "",
            "required": true
        }
    },
    "formation": {
        "worker": {
            "quantity": 1,
            "size": "basic"
        }
    }
}
