{
  "name": "JoinIDs Bot",
  "description": "Telegram bot to manage accounts and auto-join channels/groups",
  "repository": "https://github.com/yourrepo/joinids-bot",
  "logo": "",
  "keywords": ["telegram", "bot", "golang"],
  "stack": "container",
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "env": {
    "BOT_TOKEN": {
      "description": "Telegram Bot Token from @BotFather",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram User ID (get from @userinfobot)",
      "required": true
    },
    "MONGO_URI": {
      "description": "MongoDB connection URI (MongoDB Atlas recommended)",
      "required": true
    },
    "API_ID": {
      "description": "Telegram API ID from my.telegram.org",
      "required": true,
      "value": "38145963"
    },
    "API_HASH": {
      "description": "Telegram API Hash from my.telegram.org",
      "required": true,
      "value": "9325201ac0b1f87528cede06dd88484d"
    }
  },
  "addons": [],
  "buildpacks": []
}
